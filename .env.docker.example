# ===================================
# OHS Remote Backend - Docker Development Environment
# ===================================
# 
# This file is used ONLY when running via docker-compose
# It connects to the MySQL container automatically created by Docker
#
# DO NOT use this for local development outside Docker
# For local development, use .env with localhost connection
# ===================================

# -----------------------------------
# Application Configuration
# -----------------------------------

ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production-docker-f9bf78b9a18ce6d46a0cd2b0b86df9da
APP_BASE_URL=http://localhost:8000

# -----------------------------------
# Database Configuration (Docker)
# -----------------------------------

# Docker internal network connection to mysql service
# The hostname "mysql" resolves to the mysql container IP
DATABASE_URL=mysql+pymysql://ohs_dev_user:ohs_dev_password@mysql:3306/ohs_remote_dev

# -----------------------------------
# File Storage Configuration
# -----------------------------------

DATA_DIR=/app/data
USE_S3=false

# -----------------------------------
# Email Configuration (Development)
# -----------------------------------

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dev-email@gmail.com
SMTP_PASSWORD=dev-app-password
SMTP_FROM_EMAIL=noreply@ohsremote.dev
SMTP_FROM_NAME=OHS Remote Dev

# -----------------------------------
# Payment Configuration (Development)
# -----------------------------------

STRIPE_API_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL (used for Stripe Checkout success/cancel redirects)
FRONTEND_URL=http://localhost:8080

# -----------------------------------
# CORS Configuration
# -----------------------------------
# Add your ngrok URL here once the tunnel is running (check http://localhost:4040)
# Example: ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://abcd-1234.ngrok-free.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# -----------------------------------
# Logging
# -----------------------------------

LOG_LEVEL=DEBUG

# -----------------------------------
# Ngrok Configuration (Tunnel for external access)
# -----------------------------------
# Required to expose the API via ngrok for frontend and webhook access.
# Sign up at https://dashboard.ngrok.com and copy your auth token.
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
