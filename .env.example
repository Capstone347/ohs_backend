# ===================================
# OHS Remote Backend - Environment Variables
# ===================================
# 
# This file documents all required and optional environment variables
# for the OHS Remote backend application.
#
# SETUP INSTRUCTIONS:
# 
# LOCAL DEVELOPMENT (outside Docker):
# 1. Copy this file: cp .env.example .env
# 2. Fill in the required values (marked with ...)
# 3. Run: docker-compose up mysql (starts only database)
# 4. Run: source venv/bin/activate && uvicorn app.main:app --reload
#
# DOCKER DEVELOPMENT:
# 1. Use .env.docker (already configured)
# 2. Run: docker-compose up
# 3. Database is automatically created
#
# PRODUCTION:
# 1. Set all required environment variables in your deployment platform
# 2. Use secure secrets management (AWS Secrets Manager, etc.)
# 3. Never use default values for SECRET_KEY or database passwords
#
# ===================================

# -----------------------------------
# Application Configuration
# -----------------------------------

# Environment: development, staging, or production
ENVIRONMENT=development

# Debug mode (true/false) - enables detailed error messages
# WARNING: Never set to true in production
DEBUG=true

# Secret key for cryptographic operations (JWT tokens, sessions)
# CRITICAL: Generate a secure random string for production
# Generate with: openssl rand -hex 32
SECRET_KEY=...

# -----------------------------------
# Database Configuration
# -----------------------------------

# MySQL connection string
# Format: mysql+pymysql://username:password@host:port/database
# 
# DOCKER DEVELOPMENT (inside container):
#   Use .env.docker file instead - already configured
#   Connection: mysql+pymysql://ohs_dev_user:ohs_dev_password@mysql:3306/ohs_remote_dev
#
# LOCAL DEVELOPMENT (outside Docker, connecting to Docker MySQL):
#   mysql+pymysql://root:root_password@localhost:3307/ohs_remote_dev
#
# LOCAL DEVELOPMENT (your own MySQL):
#   mysql+pymysql://your_user:your_password@localhost:3306/ohs_remote_dev
#
# PRODUCTION:
#   Use your cloud database connection string (RDS, Cloud SQL, etc.)
#   Example: mysql+pymysql://prod_user:secure_password@db.example.com:3306/ohs_remote
#
DATABASE_URL=mysql+pymysql://root:root_password@localhost:3307/ohs_remote_dev

# -----------------------------------
# File Storage Configuration
# -----------------------------------

# Base directory for local file storage (Phase 1)
# Docker default: /app/data
# Local default: ./data
DATA_DIR=/app/data

# Use AWS S3 for file storage (Phase 3+)
USE_S3=false

# S3 Configuration (only needed if USE_S3=true)
S3_BUCKET_NAME=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------
# Email Configuration (SMTP)
# -----------------------------------

# SMTP server hostname
# Examples:
# - Gmail: smtp.gmail.com
# - SendGrid: smtp.sendgrid.net
# - Amazon SES: email-smtp.us-east-1.amazonaws.com
SMTP_HOST=...

# SMTP server port (usually 587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP authentication credentials
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
# For SendGrid: Username is "apikey", password is your API key
SMTP_USER=...
SMTP_PASSWORD=...

# Email sender configuration
SMTP_FROM_EMAIL=noreply@ohsremote.com
SMTP_FROM_NAME=OHS Remote

# -----------------------------------
# Payment Processing (Stripe)
# -----------------------------------

# Stripe API credentials
# Get from: https://dashboard.stripe.com/apikeys
#
# Phase 1: Use test mode keys (sk_test_...)
# Production: Use live mode keys (sk_live_...)
STRIPE_API_KEY=sk_test_...

# Stripe publishable key (exposed to frontend for Checkout redirect)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook signing secret
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL (used for Stripe Checkout success/cancel redirects)
FRONTEND_URL=http://localhost:8080

# -----------------------------------
# CORS Configuration
# -----------------------------------

# Allowed origins for Cross-Origin Resource Sharing
# Comma-separated list of frontend URLs
# Examples:
# - Development: http://localhost:3000,http://localhost:8080
# - Production: https://app.ohsremote.com,https://www.ohsremote.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------
# Logging Configuration
# -----------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------
# File Upload Limits
# -----------------------------------

# Maximum logo file size in megabytes
MAX_LOGO_SIZE_MB=5

# Allowed logo file extensions (comma-separated)
ALLOWED_LOGO_EXTENSIONS=.png,.jpg,.jpeg,.svg

# -----------------------------------
# Phase 2+ Configuration (Optional)
# -----------------------------------

# Redis for Celery task queue (Phase 2+)
# REDIS_URL=redis://localhost:6379/0

# OpenAI API for AI content generation (Phase 2+)
# OPENAI_API_KEY=sk-...

# -----------------------------------
# Ngrok Configuration (Docker tunnel for external access)
# -----------------------------------

# Required when running via docker-compose to expose the API publicly.
# Used by frontend and external webhooks (e.g. Stripe).
# Sign up at https://dashboard.ngrok.com and copy your auth token.
# This variable is read directly by the ngrok container, NOT by the app.
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# -----------------------------------
# Notes and Best Practices
# -----------------------------------
#
# SECURITY:
# - Never commit .env file to version control
# - Use strong, randomly generated secrets in production
# - Rotate credentials regularly
# - Use different credentials for each environment
#
# DOCKER:
# - docker-compose.yml provides defaults for local development
# - Override values by creating .env file in project root
# - Docker will automatically load .env if present
#
# TESTING:
# - Create .env.test for test environment with test database
# - Use mock services (mock SMTP, mock Stripe) for unit tests
#
# DEPLOYMENT:
# - Use environment-specific files: .env.staging, .env.production
# - Consider using secret management services (AWS Secrets Manager, etc.)
# - Never store production credentials in version control
#
